# ============================================
# 味记 AI 服务 - 环境变量模板
# ============================================
# 复制本文件为 .env 并填入真实值；.env 不会被提交到 git
# 缺失任意 key 时服务仍可启动，对应端点降级返回 mock 数据

# ---- 火山方舟 AI（首选能力）----
# 火山方舟 API Key，申请：https://console.volcengine.com/ark
ARK_API_KEY=
# 以下三项均有默认值，无需填写；如需切换模型/接入点，在方舟控制台「在线推理」
# 创建推理接入点后，用其 endpoint ID 覆盖默认值即可。
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 豆包多模态模型（菜品识别 + 菜谱推荐）
# ARK_MODEL_MULTIMODAL=ep-m-20260116220530-jzfsx
# 豆包 Seedream 图像编辑/生成模型
# ARK_MODEL_SEEDREAM=ep-m-20260503112555-b4j8d
# ark 请求超时秒数（多模态识别/生图耗时长，默认 120；上游网关与前端超时需 > 此值）
# ARK_TIMEOUT=120

# ---- 火山引擎 TOS 对象存储（图片中转）----
# Access Key ID，与火山引擎共用 AK/SK
VOLCANO_ACCESS_KEY=
# Secret Access Key
VOLCANO_SECRET_KEY=
# TOS 桶名（默认 ark-auto-2103850221-cn-beijing-default）
TOS_BUCKET=ark-auto-2103850221-cn-beijing-default
# TOS 区域（默认 cn-beijing）
TOS_REGION=cn-beijing
# TOS endpoint（可选，缺省由 SDK 按 region 推导）
# TOS_ENDPOINT=

# ---- 百度 AI 菜品识别（兜底）----
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# ---- OpenAI GPT-4o（兜底识别 + 通义千问复用）----
OPENAI_API_KEY=
# 兜底识别模型（默认 gpt-4o）
# OPENAI_MODEL=gpt-4o

# ---- 通义千问（兜底推荐，可选）----
# QWEN_API_KEY=
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 推荐模型（默认 qwen-turbo）
# QWEN_MODEL=qwen-turbo

# ---- 讯飞语音识别（兜底）----
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=

# ---- 腾讯云图片审核（兜底）----
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
