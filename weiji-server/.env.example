# 味记 weiji-server 环境变量示例
# ------------------------------------------------------------
# 用法：cp .env.example .env 后按需修改。bootstrap.ts 顶部 `import 'dotenv/config'` 会自动加载。
# .env 文件已加入 .gitignore，不会提交；请勿在 .env 中提交真实密钥。
# 测试入口（createApp）不依赖 .env：memory 模式 + 开发默认 JWT 即可运行 CI。

# 运行环境：development（默认）/ production
# production 下必须显式设置 JWT_SECRET，否则启动即报错退出
NODE_ENV=development

# 服务监听端口（默认 8001）
PORT=8001

# JWT 密钥：生产环境必填；非 production 未设置时回退开发默认值并警告
# 建议用 `openssl rand -hex 32` 生成强随机串
JWT_SECRET=

# 存储驱动：memory（默认，内存数组+种子数据）/ mysql（关系型数据库，需先执行 db/init.sql）
DB_DRIVER=memory

# MySQL 连接参数（仅 DB_DRIVER=mysql 时生效）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=weiji

# weiji-ai 服务地址（FastAPI，默认监听 :8002）
AI_SERVICE_URL=http://localhost:8002
