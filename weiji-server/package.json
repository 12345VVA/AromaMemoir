{
  "name": "weiji-server",
  "version": "0.1.0",
  "description": "味记 cool-admin 业务后端服务（Midway.js 风格装饰器 + Koa 简化方案）",
  "private": true,
  "scripts": {
    "dev": "ts-node src/bootstrap.ts",
    "build": "tsc",
    "start": "node dist/bootstrap.js",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts",
    "test:integration": "node --import tsx --test tests/integration/*.test.ts",
    "test": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^13.0.0",
    "@midwayjs/core": "^3.20.0",
    "@midwayjs/decorator": "^3.20.0",
    "@midwayjs/koa": "^3.20.0",
    "@midwayjs/validate": "^3.20.0",
    "@types/koa-helmet": "^6.0.8",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.0",
    "koa": "^2.15.0",
    "koa-bodyparser": "^4.4.0",
    "koa-helmet": "^9.0.0",
    "koa-ratelimit": "^6.0.0",
    "mysql2": "^3.22.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/koa": "^2.15.0",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.5",
    "@types/koa-bodyparser": "^4.3.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "supertest": "^6.3.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
