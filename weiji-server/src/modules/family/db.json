    {
      "id": 1,
      "familyId": 1,
      "authorId": 1,
      "name": "红烧牛肉面",
      "category": "面食",
      "ingredients": [
        {
          "name": "牛腩",
          "amount": "300g",
          "unit": "g"
        },
        {
          "name": "面条",
          "amount": "200g",
          "unit": "g"
        },
        {
          "name": "青菜",
          "amount": "100g",
          "unit": "g"
        },
        {
          "name": "八角",
          "amount": "2个",
          "unit": "个"
        }
      ],
      "steps": [
        {
          "stepNum": 1,
          "text": "牛腩切块冷水下锅焯水去血沫",
          "imageUrl": "/upload/demo/beef-noodle-s1.png"
        },
        {
          "stepNum": 2,
          "text": "热锅冷油爆香葱姜八角，下牛腩翻炒上色",
          "imageUrl": "/upload/demo/beef-noodle-s2.png"
        },
        {
          "stepNum": 3,
          "text": "加开水没过牛肉，小火炖煮90分钟",
          "imageUrl": "/upload/demo/beef-noodle-s3.png"
        },
        {
          "stepNum": 4,
          "text": "另锅煮面，出锅前烫青菜，浇上牛肉汤",
          "imageUrl": "/upload/demo/beef-noodle-s4.png"
        }
      ],
      "coverUrl": "/upload/demo/beef-noodle-s4.png",
      "difficulty": "medium",
      "cookTime": 90,
      "visibility": "family"
    },
